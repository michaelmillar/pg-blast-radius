      "summary": "SET NOT NULL on \"users\".\"email\" requires full table scan",
      "explanation": "SET NOT NULL acquires ACCESS EXCLUSIVE lock and performs a full table scan to verify no NULLs exist. On PG 12+, the scan is skipped if a pre-validated CHECK (column IS NOT NULL) constraint already exists.",
      "recipe": {
        "title": "Safe SET NOT NULL for \"users\".\"email\"",
        "steps": [
          {
            "phase": "expand",
            "description": "Add CHECK constraint with NOT VALID (brief lock, no scan)",
            "sql": "ALTER TABLE \"users\" ADD CONSTRAINT \"users_email_not_null\" CHECK (\"email\" IS NOT NULL) NOT VALID;",
            "separate_transaction": false
          },
          {
            "phase": "validate",
            "description": "Validate constraint (SHARE UPDATE EXCLUSIVE, non-blocking)",
            "sql": "ALTER TABLE \"users\" VALIDATE CONSTRAINT \"users_email_not_null\";",
            "separate_transaction": true
          },
          {
            "phase": "switch",
            "description": "SET NOT NULL is now instant (PG 12+) as CHECK already proves it",
            "sql": "ALTER TABLE \"users\" ALTER COLUMN \"email\" SET NOT NULL;",
            "separate_transaction": true
          },
          {
            "phase": "contract",
            "description": "Drop the redundant CHECK constraint",
            "sql": "ALTER TABLE \"users\" DROP CONSTRAINT \"users_email_not_null\";",
            "separate_transaction": false
          }
        ]
